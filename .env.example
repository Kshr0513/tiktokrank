# Database — ローカル開発はSQLiteファイル、本番はTurso
DATABASE_URL="file:./dev.db"

# Turso (本番) — Vercel環境変数に設定する
# TURSO_DATABASE_URL="libsql://<db-name>-<org>.turso.io"
# TURSO_AUTH_TOKEN="eyJh..."

# IP anonymization salt (generate with: openssl rand -hex 32)
IP_SALT="change-me-to-a-random-secret"

# Basic auth for /admin
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me"

# Your public base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL="https://tiktokrank.example.com"

# Cron job secret — Vercel automatically sets this in production
# For local testing: set any string and pass as Authorization: Bearer <value>
CRON_SECRET="change-me-to-a-random-secret"
